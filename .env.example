# Inbound: Laravel (or other gateway) calls this service with:
#   Authorization: Bearer <INBOUND_SERVICE_TOKEN>
INBOUND_SERVICE_TOKEN=change-me

# Assistant → Desert API (Sanctum / service token as configured in Laravel)
DESERT_API_BASE_URL=https://your-tenant.desert-staging.link/api
DESERT_SERVICE_TOKEN=

# LLM (OpenAI by default; router can be extended per docs/PROJECT.md)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tiers (same or different models)
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_STRONG=gpt-4o

# Optional: Anthropic when using extras: pip install -e ".[anthropic]"
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Infra (Phase 1+)
DATABASE_URL=postgresql://user:pass@localhost:5432/desert_ai
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# CORS (comma-separated origins; * for dev)
CORS_ORIGINS=*

# LangSmith (optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=desert-ai-assistant
